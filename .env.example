# Runtime mode: local, paper, sandbox, live
QUANT_SYSTEM_ENV=local

# Safety defaults
LIVE_TRADING_ENABLED=false
GLOBAL_KILL_SWITCH=true

# Hummingbot API
HUMMINGBOT_API_BASE_URL=http://127.0.0.1:15888
HUMMINGBOT_API_KEY=

# Alerting; configure at least one before live activation
ALERT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_TO=
SMS_WEBHOOK_URL=

# Infrastructure
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=quant_system
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
REDIS_URL=redis://127.0.0.1:6379/0

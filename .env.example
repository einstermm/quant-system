# Runtime mode: local, paper, sandbox, live
QUANT_SYSTEM_ENV=local

# Safety defaults
LIVE_TRADING_ENABLED=false
GLOBAL_KILL_SWITCH=true

# Hummingbot API
HUMMINGBOT_API_BASE_URL=http://127.0.0.1:15888
HUMMINGBOT_API_KEY=

# Infrastructure
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=quant_system
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant
REDIS_URL=redis://127.0.0.1:6379/0
